---
const navLinks = [
  { href: '/',      label: 'Home'    },
  { href: '/blog',  label: 'Reviews' },
  { href: '/about', label: 'About'   },
];
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Mono:wght@400&display=swap" rel="stylesheet" />

<footer style="
  display: block;
  position: relative;
  overflow: hidden;
  background: #0d0d10;
  border-top: 1px solid rgba(255,255,255,0.07);
  width: 100%;
">

  <!-- ghost watermark -->
  <span style="
    position: absolute;
    bottom: -0.1em;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(4rem, 15vw, 12rem);
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1px rgba(201,168,76,0.055);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    z-index: 0;
  " aria-hidden="true">BINGE BEAR</span>

  <!-- centred column -->
  <div style="
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: clamp(3.5rem,7vh,5.5rem) clamp(1.5rem,5vw,4rem) clamp(2rem,4vh,3rem);
  ">

    <!-- bear mark -->
    <a href="/" style="display:inline-block; margin-bottom: 1.5rem; opacity: 0.82; transition: opacity 0.3s ease, transform 0.5s cubic-bezier(0.34,1.56,0.64,1);" class="footer-bear-link" aria-label="The Binge Bear">
      <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52" aria-hidden="true">
        <ellipse cx="9.5"  cy="10" rx="5.2" ry="5.2" fill="#c9a84c" opacity="0.15"/>
        <ellipse cx="9.5"  cy="10" rx="5.2" ry="5.2" stroke="#c9a84c" stroke-width="1.1"/>
        <ellipse cx="9.5"  cy="10" rx="2.5" ry="2.5" fill="#c9a84c" opacity="0.35"/>
        <ellipse cx="30.5" cy="10" rx="5.2" ry="5.2" fill="#c9a84c" opacity="0.15"/>
        <ellipse cx="30.5" cy="10" rx="5.2" ry="5.2" stroke="#c9a84c" stroke-width="1.1"/>
        <ellipse cx="30.5" cy="10" rx="2.5" ry="2.5" fill="#c9a84c" opacity="0.35"/>
        <ellipse cx="20" cy="22" rx="13.5" ry="12.5" fill="#c9a84c" opacity="0.08"/>
        <ellipse cx="20" cy="22" rx="13.5" ry="12.5" stroke="#c9a84c" stroke-width="1.1"/>
        <ellipse cx="20" cy="26.5" rx="5.5" ry="3.8" fill="#c9a84c" opacity="0.16"/>
        <ellipse cx="20" cy="26.5" rx="5.5" ry="3.8" stroke="#c9a84c" stroke-width="0.9"/>
        <ellipse cx="20" cy="24.8" rx="1.6" ry="1.1" fill="#c9a84c"/>
        <circle  cx="14.8" cy="19.5" r="1.5" fill="#c9a84c"/>
        <circle  cx="25.2" cy="19.5" r="1.5" fill="#c9a84c"/>
        <line x1="12.5" y1="16.5" x2="17"   y2="17.2" stroke="#c9a84c" stroke-width="0.9" stroke-linecap="round" opacity="0.65"/>
        <line x1="23"   y1="17.2" x2="27.5" y2="16.5" stroke="#c9a84c" stroke-width="0.9" stroke-linecap="round" opacity="0.65"/>
      </svg>
    </a>

    <!-- wordmark -->
    <a href="/" style="
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
      text-decoration: none;
      margin-bottom: 1.25rem;
      line-height: 1;
    " class="footer-wordmark-link">
      <span style="
        display: block;
        font-family: 'DM Mono', monospace, ui-monospace;
        font-size: 9px;
        letter-spacing: .5em;
        text-transform: uppercase;
        color: #c9a84c;
        opacity: .5;
      ">The</span>
      <span style="
        display: block;
        font-family: 'Cormorant Garamond', Georgia, serif;
        font-size: clamp(2.4rem, 5.5vw, 3.8rem);
        font-weight: 300;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: #f0ede6;
        font-style: normal;
      ">BINGE <em style="font-style:italic; color:#c9a84c;">BEAR</em></span>
    </a>

    <!-- tagline -->
    <p style="
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(0.92rem, 2vw, 1.08rem);
      font-weight: 300;
      font-style: italic;
      color: #52525e;
      letter-spacing: .03em;
      margin: 0 0 clamp(2rem,4vh,3rem);
      padding: 0;
    ">Reviews for people who actually binge.</p>

    <!-- nav -->
    <nav aria-label="Footer navigation" style="
      display: flex;
      align-items: center;
      gap: 28px;
      margin-bottom: clamp(2.5rem,5vh,4rem);
    ">
      {navLinks.map(({ href, label }, i) => (
        <>
          <a
            href={href}
            class="footer-nav-link"
            style="
              font-family: 'DM Mono', monospace, ui-monospace;
              font-size: 10px;
              letter-spacing: .22em;
              text-transform: uppercase;
              color: #52525e;
              text-decoration: none;
              position: relative;
              padding-bottom: 3px;
              transition: color 0.22s ease;
            "
          >{label}</a>
          {i < navLinks.length - 1 && (
            <span aria-hidden="true" style="
              font-size: 4px;
              color: #c9a84c;
              opacity: 0.25;
              line-height: 1;
              flex-shrink: 0;
            ">◆</span>
          )}
        </>
      ))}
    </nav>

    <!-- bottom rule + copyright -->
    <div style="
      width: 100%;
      max-width: 460px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.25rem;
    ">
      <div style="width:100%; height:1px; background:rgba(255,255,255,0.06);"></div>
      <p style="
        font-family: 'DM Mono', monospace, ui-monospace;
        font-size: 9px;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: #3a3a44;
        margin: 0;
        padding: 0;
      ">&copy; 2026 The Binge Bear. All rights reserved.</p>
    </div>

  </div>
</footer>

<style is:global>
  .footer-bear-link:hover  { opacity: 1 !important; transform: scale(1.1) rotate(-4deg) !important; }

  .footer-wordmark-link:hover span:last-child { color: #ffffff !important; }
  .footer-wordmark-link:hover span:first-child { opacity: 1 !important; }

  .footer-nav-link:hover { color: #f0ede6 !important; }
  .footer-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: #c9a84c;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .footer-nav-link:hover::after { transform: scaleX(1); }
</style>