---
const navLinks = [
  { href: '/',      label: 'Home'    },
  { href: '/blog',  label: 'Reviews' },
  { href: '/about', label: 'About'   },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header id="site-header">
  <div class="header-inner">

    <!-- LOGO -->
    <a href="/" class="logo" aria-label="The Binge Bear — Home">
      <!-- Bear Mark SVG -->
      <svg class="bear-mark" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Ear left -->
        <ellipse cx="9.5" cy="10" rx="5.2" ry="5.2" fill="#c9a84c" opacity="0.15"/>
        <ellipse cx="9.5" cy="10" rx="5.2" ry="5.2" stroke="#c9a84c" stroke-width="1.1"/>
        <ellipse cx="9.5" cy="10" rx="2.5" ry="2.5" fill="#c9a84c" opacity="0.35"/>
        <!-- Ear right -->
        <ellipse cx="30.5" cy="10" rx="5.2" ry="5.2" fill="#c9a84c" opacity="0.15"/>
        <ellipse cx="30.5" cy="10" rx="5.2" ry="5.2" stroke="#c9a84c" stroke-width="1.1"/>
        <ellipse cx="30.5" cy="10" rx="2.5" ry="2.5" fill="#c9a84c" opacity="0.35"/>
        <!-- Head -->
        <ellipse cx="20" cy="22" rx="13.5" ry="12.5" fill="#c9a84c" opacity="0.08"/>
        <ellipse cx="20" cy="22" rx="13.5" ry="12.5" stroke="#c9a84c" stroke-width="1.1"/>
        <!-- Snout -->
        <ellipse cx="20" cy="26.5" rx="5.5" ry="3.8" fill="#c9a84c" opacity="0.18"/>
        <ellipse cx="20" cy="26.5" rx="5.5" ry="3.8" stroke="#c9a84c" stroke-width="0.9"/>
        <!-- Nose -->
        <ellipse cx="20" cy="24.8" rx="1.6" ry="1.1" fill="#c9a84c"/>
        <!-- Eye left -->
        <circle cx="14.8" cy="19.5" r="1.5" fill="#c9a84c"/>
        <!-- Eye right -->
        <circle cx="25.2" cy="19.5" r="1.5" fill="#c9a84c"/>
        <!-- Brow left — subtle line -->
        <line x1="12.5" y1="16.5" x2="17" y2="17.2" stroke="#c9a84c" stroke-width="0.9" stroke-linecap="round" opacity="0.7"/>
        <!-- Brow right -->
        <line x1="23" y1="17.2" x2="27.5" y2="16.5" stroke="#c9a84c" stroke-width="0.9" stroke-linecap="round" opacity="0.7"/>
      </svg>

      <div class="logo-text">
        <span class="logo-the">The</span>
        <span class="logo-name">BINGE <em>BEAR</em></span>
      </div>
    </a>

    <!-- DESKTOP NAV -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`nav-cell ${isActive(href) ? 'active' : ''}`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- MOBILE TOGGLE -->
    <button
      class="menu-toggle"
      id="menuToggle"
      aria-expanded="false"
      aria-controls="mobileMenu"
      aria-label="Open menu"
    >
      <span class="burger-icon" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </button>

  </div>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobileMenu" aria-hidden="true" role="dialog" aria-label="Navigation menu">
    {navLinks.map(({ href, label }, i) => (
      <a
        href={href}
        class={`mobile-cell ${isActive(href) ? 'active' : ''}`}
        aria-current={isActive(href) ? 'page' : undefined}
        style={`--i:${i}`}
      >
        <span class="mobile-num" aria-hidden="true">{String(i + 1).padStart(2,'0')}</span>
        <span class="mobile-label">{label}</span>
        <span class="mobile-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</header>

<style>
  :root {
    --hdr-h: 68px;
    --hdr-black: #080809;
    --hdr-gold: #c9a84c;
    --hdr-cream: #f0ede6;
    --hdr-muted: #52525e;
    --hdr-border: rgba(255,255,255,0.08);
  }

  /* ── SHELL ─────────────────────────────────────────── */
  #site-header {
    position: fixed;
    inset-block-start: 0;
    inset-inline: 0;
    z-index: 200;
    background: rgba(8,8,9,0.88);
    backdrop-filter: blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border-bottom: 1px solid var(--hdr-border);
    transition: background 0.3s ease;
  }

  #site-header.scrolled {
    background: rgba(8,8,9,0.97);
  }

  /* ── INNER ROW ─────────────────────────────────────── */
  .header-inner {
    height: var(--hdr-h);
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* ── LOGO ──────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .bear-mark {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }

  .logo:hover .bear-mark {
    transform: scale(1.1) rotate(-4deg);
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    gap: 1px;
    line-height: 1;
  }

  .logo-the {
    font-family: 'DM Mono', monospace, ui-monospace;
    font-size: 8.5px;
    letter-spacing: .35em;
    text-transform: uppercase;
    color: var(--hdr-gold);
    opacity: .65;
  }

  .logo-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 17.5px;
    font-weight: 400;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--hdr-cream);
    font-style: normal;
    transition: color 0.25s;
  }

  .logo-name em {
    font-style: italic;
    color: var(--hdr-gold);
  }

  .logo:hover .logo-name {
    color: #fff;
  }

  /* ── DESKTOP NAV CELLS ─────────────────────────────── */
  .desktop-nav {
    display: flex;
    align-items: stretch;
    height: 100%;
    margin-left: auto;
  }

  .nav-cell {
    display: flex;
    align-items: center;
    padding: 0 22px;
    font-family: 'DM Mono', monospace, ui-monospace;
    font-size: 10.5px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--hdr-muted);
    text-decoration: none;
    border-left: 1px solid var(--hdr-border);
    position: relative;
    transition: color 0.22s, background 0.22s;
  }

  .nav-cell:last-child {
    border-right: 1px solid var(--hdr-border);
  }

  /* gold bottom bar reveal */
  .nav-cell::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--hdr-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
  }

  .nav-cell:hover {
    color: var(--hdr-cream);
    background: rgba(201,168,76,0.04);
  }

  .nav-cell:hover::after {
    transform: scaleX(1);
  }

  .nav-cell.active {
    color: var(--hdr-gold);
    background: rgba(201,168,76,0.06);
  }

  .nav-cell.active::after {
    transform: scaleX(1);
  }

  /* ── MOBILE TOGGLE ─────────────────────────────────── */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: none;
    border: 1px solid var(--hdr-border);
    cursor: pointer;
    flex-shrink: 0;
    transition: border-color 0.25s;
  }

  .menu-toggle:hover {
    border-color: rgba(201,168,76,0.35);
  }

  .burger-icon {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 16px;
  }

  .burger-icon span {
    display: block;
    height: 1px;
    background: var(--hdr-cream);
    transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
  }

  .burger-icon span:last-child { width: 10px; }

  .menu-toggle[aria-expanded="true"] .burger-icon span:first-child {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .burger-icon span:last-child {
    width: 16px;
    transform: translateY(-0px) rotate(-45deg);
  }

  /* ── MOBILE MENU ───────────────────────────────────── */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    pointer-events: none;
    border-top: 1px solid transparent;
    transition:
      max-height 0.4s cubic-bezier(0.25,0.46,0.45,0.94),
      border-color 0.3s ease;
  }

  .mobile-menu[aria-hidden="false"] {
    max-height: 320px;
    pointer-events: auto;
    border-top-color: var(--hdr-border);
  }

  .mobile-cell {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 16px clamp(1rem, 4vw, 3rem);
    border-bottom: 1px solid var(--hdr-border);
    text-decoration: none;
    background: rgba(8,8,9,0.96);
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity 0.3s ease calc(var(--i) * 0.06s),
      transform 0.3s ease calc(var(--i) * 0.06s),
      background 0.2s ease;
  }

  .mobile-menu[aria-hidden="false"] .mobile-cell {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-cell:hover {
    background: rgba(201,168,76,0.05);
  }

  .mobile-num {
    font-family: 'DM Mono', monospace, ui-monospace;
    font-size: 9.5px;
    letter-spacing: .18em;
    color: var(--hdr-gold);
    opacity: .45;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .mobile-cell:hover .mobile-num,
  .mobile-cell.active .mobile-num {
    opacity: 1;
  }

  .mobile-label {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: .04em;
    color: var(--hdr-muted);
    flex: 1;
    transition: color 0.2s;
  }

  .mobile-cell:hover .mobile-label,
  .mobile-cell.active .mobile-label {
    color: var(--hdr-cream);
  }

  .mobile-cell.active .mobile-label {
    color: var(--hdr-gold);
  }

  .mobile-arrow {
    font-size: .8rem;
    color: var(--hdr-gold);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.25s ease;
  }

  .mobile-cell:hover .mobile-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 620px) {
    .desktop-nav { display: none; }
    .menu-toggle { display: flex; }
  }

  /* push body below fixed header */
  :global(body) {
    padding-top: var(--hdr-h);
  }
</style>

<script>
  const header  = document.getElementById('site-header')!;
  const toggle  = document.getElementById('menuToggle')!;
  const menu    = document.getElementById('mobileMenu')!;

  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  toggle.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    menu.setAttribute('aria-hidden', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!header.contains(e.target as Node)) {
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    }
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>