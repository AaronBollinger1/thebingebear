---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Syne:wght@400;500;700&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      :root {
        --black:    #080809;
        --surface:  #101013;
        --surface2: #18181d;
        --border:   rgba(255,255,255,0.07);
        --gold:     #c9a84c;
        --gold-dim: #8a6f2e;
        --cream:    #f0ede6;
        --muted:    #6b6b7a;
        --prose-w:  700px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { background: var(--black); color: var(--cream); scroll-behavior: smooth; }

      body {
        font-family: 'Syne', sans-serif;
        background: var(--black);
        overflow-x: hidden;
        min-height: 100vh;
      }

      /* film grain */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
        opacity: 0.35;
      }

      header {
        background: rgba(8,8,9,0.75) !important;
        border-bottom: 1px solid var(--border) !important;
        backdrop-filter: blur(20px) !important;
        -webkit-backdrop-filter: blur(20px) !important;
      }

      main { width: 100%; }

      /* ── HERO ──────────────────────────────────────────── */
      .review-hero {
        position: relative;
        width: 100%;
        height: min(72vh, 640px);
        overflow: hidden;
      }

      .review-hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: brightness(0.45) saturate(0.65);
        transform: scale(1.04);
        animation: heroReveal 1.4s cubic-bezier(0.25,0.46,0.45,0.94) forwards;
      }

      @keyframes heroReveal {
        from { transform: scale(1.08); filter: brightness(0.2) saturate(0.4); }
        to   { transform: scale(1.04); filter: brightness(0.45) saturate(0.65); }
      }

      .review-hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to bottom,
          rgba(8,8,9,0.45) 0%,
          rgba(8,8,9,0.05) 30%,
          rgba(8,8,9,0.05) 55%,
          rgba(8,8,9,0.88) 82%,
          rgba(8,8,9,1)    100%
        );
      }

      .review-hero-placeholder {
        width: 100%;
        height: 100%;
        background: var(--surface);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .review-hero-placeholder::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      .review-hero-placeholder::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
      }

      .placeholder-initial {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(10rem, 20vw, 18rem);
        font-weight: 300;
        font-style: italic;
        color: rgba(201,168,76,0.08);
        line-height: 1;
        position: relative;
        z-index: 1;
        user-select: none;
      }

      /* ── TITLE BLOCK ───────────────────────────────────── */
      .review-title-block {
        position: relative;
        z-index: 2;
        max-width: var(--prose-w);
        margin: -13rem auto 0;
        padding: 0 clamp(1.25rem, 5vw, 2rem) clamp(2.5rem, 5vh, 4rem);
        animation: fadeUp 0.9s 0.3s cubic-bezier(0.25,0.46,0.45,0.94) both;
      }

      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .review-eyebrow {
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .review-eyebrow::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: var(--gold);
        opacity: 0.7;
        flex-shrink: 0;
      }

      .review-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.8rem, 6vw, 5.5rem);
        font-weight: 300;
        line-height: 0.92;
        letter-spacing: -0.025em;
        color: var(--cream);
        margin-bottom: 1.5rem;
      }

      .review-description {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.1rem, 2vw, 1.35rem);
        font-weight: 300;
        font-style: italic;
        line-height: 1.55;
        color: rgba(240,237,230,0.55);
        margin-bottom: 2rem;
        max-width: 54ch;
      }

      .review-meta-row {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }

      .review-date {
        font-family: 'DM Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .review-updated {
        font-family: 'DM Mono', monospace;
        font-size: 0.58rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(107,107,122,0.65);
      }

      .meta-dot {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: var(--gold-dim);
        opacity: 0.5;
        flex-shrink: 0;
      }

      /* ── ORNAMENTAL RULE ───────────────────────────────── */
      .review-rule {
        max-width: var(--prose-w);
        margin: 0 auto clamp(2.5rem, 5vh, 4rem);
        padding: 0 clamp(1.25rem, 5vw, 2rem);
        display: flex;
        align-items: center;
        gap: 1rem;
        animation: fadeUp 0.9s 0.5s cubic-bezier(0.25,0.46,0.45,0.94) both;
      }

      .review-rule-line {
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      .review-rule-ornament {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        color: var(--gold);
        opacity: 0.45;
        line-height: 1;
      }

      /* ── PROSE WRAP ────────────────────────────────────── */
      .prose-wrap {
        max-width: var(--prose-w);
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 5vw, 2rem) clamp(5rem, 10vh, 8rem);
        animation: fadeUp 0.9s 0.6s cubic-bezier(0.25,0.46,0.45,0.94) both;
      }

      /* ── PARAGRAPHS ────────────────────────────────────── */
      .prose-wrap :global(p) {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.08rem, 1.8vw, 1.22rem);
        line-height: 1.88;
        color: rgba(240,237,230,0.78);
        margin-bottom: 1.7em;
        font-weight: 400;
      }

      /* drop cap on first paragraph only */
      .prose-wrap :global(p:first-of-type::first-letter) {
        font-family: 'Cormorant Garamond', serif;
        font-size: 4.4em;
        font-weight: 300;
        float: left;
        line-height: 0.76;
        margin: 0.1em 0.14em 0 0;
        color: var(--gold);
      }

      /* ── HEADINGS ──────────────────────────────────────── */
      .prose-wrap :global(h2) {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        font-weight: 300;
        font-style: italic;
        letter-spacing: -0.015em;
        color: var(--cream);
        margin: 3em 0 0.85em;
        line-height: 1.1;
        position: relative;
        padding-left: 1.1rem;
      }

      .prose-wrap :global(h2::before) {
        content: '';
        position: absolute;
        left: 0;
        top: 0.15em;
        bottom: 0.1em;
        width: 2px;
        background: var(--gold);
        opacity: 0.5;
      }

      .prose-wrap :global(h3) {
        font-family: 'DM Mono', monospace;
        font-size: clamp(0.65rem, 1.2vw, 0.75rem);
        font-weight: 500;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        margin: 2.5em 0 1em;
        display: flex;
        align-items: center;
        gap: 0.85rem;
      }

      .prose-wrap :global(h3::after) {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
        max-width: 120px;
      }

      /* ── BLOCKQUOTE ────────────────────────────────────── */
      .prose-wrap :global(blockquote) {
        position: relative;
        margin: 3em 0;
        padding: 2.25rem 2.5rem 2.25rem 3rem;
        background: var(--surface);
        border: none;
        border-left: none;
        overflow: hidden;
      }

      /* top + bottom hairlines with gold fade */
      .prose-wrap :global(blockquote::before) {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(to right, var(--gold), rgba(201,168,76,0.1) 60%, transparent);
      }

      .prose-wrap :global(blockquote::after) {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(to right, rgba(201,168,76,0.25), transparent 50%);
      }

      /* gold left bar */
      .prose-wrap :global(blockquote > *) {
        position: relative;
        z-index: 1;
      }

      .prose-wrap :global(blockquote p) {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.2rem, 2.2vw, 1.45rem);
        font-weight: 300;
        font-style: italic;
        line-height: 1.65;
        color: rgba(240,237,230,0.82);
        margin: 0;
        letter-spacing: 0.01em;
      }

      /* decorative quote mark */
      .prose-wrap :global(blockquote p::before) {
        content: '\201C';
        font-family: 'Cormorant Garamond', serif;
        font-size: 5rem;
        color: var(--gold);
        opacity: 0.18;
        position: absolute;
        top: -1.6rem;
        left: -0.5rem;
        line-height: 1;
        pointer-events: none;
      }

      /* vertical gold bar */
      .prose-wrap :global(blockquote) {
        border-left: 2px solid rgba(201,168,76,0.4);
      }

      /* attribution line if present */
      .prose-wrap :global(blockquote cite),
      .prose-wrap :global(blockquote footer) {
        display: block;
        margin-top: 1.1rem;
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--gold);
        opacity: 0.55;
        font-style: normal;
      }

      /* ── LINKS ─────────────────────────────────────────── */
      .prose-wrap :global(a) {
        color: var(--gold);
        text-decoration: none;
        border-bottom: 1px solid rgba(201,168,76,0.28);
        transition: color 0.2s, border-color 0.2s;
      }

      .prose-wrap :global(a:hover) {
        color: #e2be65;
        border-bottom-color: rgba(226,190,101,0.65);
      }

      /* ── INLINE FORMATTING ─────────────────────────────── */
      .prose-wrap :global(strong) {
        font-weight: 600;
        color: var(--cream);
      }

      .prose-wrap :global(em) {
        font-style: italic;
        color: rgba(240,237,230,0.9);
      }

      /* ── LISTS ─────────────────────────────────────────── */
      .prose-wrap :global(ul),
      .prose-wrap :global(ol) {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(1.05rem, 1.8vw, 1.18rem);
        color: rgba(240,237,230,0.75);
        padding-left: 0;
        margin-bottom: 1.7em;
        line-height: 1.8;
        list-style: none;
      }

      .prose-wrap :global(ul li) {
        padding-left: 1.5em;
        position: relative;
        margin-bottom: 0.5em;
      }

      .prose-wrap :global(ul li::before) {
        content: '◆';
        position: absolute;
        left: 0;
        font-size: 0.35em;
        color: var(--gold);
        opacity: 0.6;
        top: 0.55em;
      }

      .prose-wrap :global(ol) {
        counter-reset: ol-counter;
      }

      .prose-wrap :global(ol li) {
        padding-left: 2em;
        position: relative;
        margin-bottom: 0.5em;
        counter-increment: ol-counter;
      }

      .prose-wrap :global(ol li::before) {
        content: counter(ol-counter, decimal-leading-zero);
        position: absolute;
        left: 0;
        font-family: 'DM Mono', monospace;
        font-size: 0.62em;
        color: var(--gold);
        opacity: 0.55;
        top: 0.3em;
        letter-spacing: 0.05em;
      }

      /* ── HR ────────────────────────────────────────────── */
      .prose-wrap :global(hr) {
        border: none;
        margin: 3.5em 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        position: relative;
      }

      .prose-wrap :global(hr::before) {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--border));
      }

      .prose-wrap :global(hr::after) {
        content: '✦';
        font-size: 0.5rem;
        color: var(--gold);
        opacity: 0.4;
        flex-shrink: 0;
      }

      /* ── CODE ──────────────────────────────────────────── */
      .prose-wrap :global(code) {
        font-family: 'DM Mono', monospace;
        font-size: 0.82em;
        background: var(--surface2);
        color: var(--gold);
        padding: 0.15em 0.45em;
        border: 1px solid var(--border);
      }

      .prose-wrap :global(pre) {
        background: var(--surface);
        border: 1px solid var(--border);
        border-left: 2px solid rgba(201,168,76,0.3);
        padding: 1.75em;
        overflow-x: auto;
        margin-bottom: 1.7em;
      }

      .prose-wrap :global(pre code) {
        background: none;
        border: none;
        padding: 0;
        color: var(--cream);
        font-size: 0.88em;
      }

      /* ── IMAGES ────────────────────────────────────────── */
      .prose-wrap :global(img) {
        width: 100%;
        height: auto;
        display: block;
        margin: 2.5em 0;
        filter: brightness(0.85) saturate(0.8);
        transition: filter 0.5s ease;
      }

      .prose-wrap :global(img:hover) {
        filter: brightness(1) saturate(1);
      }

      .prose-wrap :global(figure) {
        margin: 2.5em 0;
      }

      .prose-wrap :global(figcaption) {
        font-family: 'DM Mono', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        margin-top: 0.75rem;
        text-align: center;
        opacity: 0.65;
      }

      /* ── BACK LINK ─────────────────────────────────────── */
      .back-link-wrap {
        max-width: var(--prose-w);
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 5vw, 2rem) 3rem;
        border-top: 1px solid var(--border);
      }

      .back-link {
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding-top: 2rem;
        transition: color 0.25s, gap 0.25s;
      }

      .back-link::before { content: '←'; }

      .back-link:hover {
        color: var(--gold);
        gap: 1rem;
      }

      /* ── SCROLLBAR ─────────────────────────────────────── */
      ::-webkit-scrollbar { width: 3px; }
      ::-webkit-scrollbar-track { background: var(--black); }
      ::-webkit-scrollbar-thumb { background: var(--gold-dim); }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <article>

        <div class="review-hero">
          {heroImage ? (
            <>
              <Image
                class="review-hero-img"
                width={1400}
                height={700}
                src={heroImage}
                alt={title}
              />
              <div class="review-hero-gradient"></div>
            </>
          ) : (
            <div class="review-hero-placeholder">
              <span class="placeholder-initial">{title.charAt(0)}</span>
              <div class="review-hero-gradient"></div>
            </div>
          )}
        </div>

        <div class="review-title-block">
          <div class="review-eyebrow">Film Review</div>
          <h1 class="review-title">{title}</h1>
          {description && <p class="review-description">{description}</p>}
          <div class="review-meta-row">
            <span class="review-date"><FormattedDate date={pubDate} /></span>
            {updatedDate && (
              <>
                <span class="meta-dot"></span>
                <span class="review-updated">
                  Updated <FormattedDate date={updatedDate} />
                </span>
              </>
            )}
          </div>
        </div>

        <div class="review-rule">
          <div class="review-rule-line"></div>
          <span class="review-rule-ornament">✦</span>
          <div class="review-rule-line"></div>
        </div>

        <div class="prose-wrap">
          <slot />
        </div>

      </article>

      <div class="back-link-wrap">
        <a href="/blog" class="back-link">All Reviews</a>
      </div>

    </main>

    <Footer />
  </body>
</html>